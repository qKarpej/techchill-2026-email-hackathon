# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Email account (IMAP) ───────────────────────────────────
#EMAIL_USER=you@gmail.com
#EMAIL_PASSWORD=your_app_password_here   # Gmail: 16-char App Password. Outlook: your password.


EMAIL_ACCOUNTS='[
  {"provider":"gmail","username":"example@gmail.com","password":"example"},
  {"provider":"outlook","username":"home@outlook.com","password":"yyy"}
]'



# ── IMAP server settings ───────────────────────────────────
# Gmail
#EMAIL_IMAP_HOST=imap.gmail.com
#EMAIL_IMAP_PORT=993
#EMAIL_USE_SSL=true

# Outlook / Microsoft 365 — uncomment and replace the Gmail lines above:
# EMAIL_IMAP_HOST=outlook.office365.com
# EMAIL_IMAP_PORT=993
# EMAIL_USE_SSL=true

# Generic IMAP (any provider)
# EMAIL_IMAP_HOST=mail.yourdomain.com
# EMAIL_IMAP_PORT=993
# EMAIL_USE_SSL=true
